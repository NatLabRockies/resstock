      <required>false</required>
      <model_dependent>false</model_dependent>
      <default_value>2018</default_value>
    </argument>
    <argument>
      <name>start_month</name>
      <display_name>Simulation Start Month</display_name>
      <description>Month to start the OCHRE simulation (1-12).</description>
      <type>Integer</type>
      <required>false</required>
