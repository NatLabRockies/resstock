{
  "$defs": {
    "ComparisonTypes": {
      "description": "Different kinds of comparison between the upgrade and the baseline.",
      "enum": [
        "absolute",
        "mean",
        "savings",
        "percent_savings"
      ],
      "title": "ComparisonTypes",
      "type": "string"
    },
    "QuantityGroup": {
      "additionalProperties": false,
      "description": "Definition of a quantity group with constituents and sum",
      "properties": {
        "name": {
          "description": "Name of the quantity group",
          "title": "Name",
          "type": "string"
        },
        "constituents": {
          "description": "List of constituent columns",
          "items": {
            "type": "string"
          },
          "title": "Constituents",
          "type": "array"
        },
        "sum": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Column name for the sum quantity",
          "title": "Sum"
        }
      },
      "required": [
        "name",
        "constituents"
      ],
      "title": "QuantityGroup",
      "type": "object"
    },
    "SelectionLogic": {
      "description": "Selection logic for plots based on upgrade apply logic rules",
      "properties": {
        "and": {
          "anyOf": [
            {
              "$ref": "#/$defs/SelectionLogic"
            },
            {
              "items": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/SelectionLogic"
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "And"
        },
        "or": {
          "anyOf": [
            {
              "$ref": "#/$defs/SelectionLogic"
            },
            {
              "items": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/SelectionLogic"
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Or"
        },
        "not": {
          "anyOf": [
            {
              "$ref": "#/$defs/SelectionLogic"
            },
            {
              "items": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/SelectionLogic"
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Not"
        }
      },
      "title": "SelectionLogic",
      "type": "object"
    },
    "UpgradeInclusion": {
      "description": "Different ways to include a quantity in a plot.",
      "enum": [
        "all",
        "applied_only"
      ],
      "title": "UpgradeInclusion",
      "type": "string"
    },
    "VacancyInclusion": {
      "description": "Different ways to include a quantity in a plot.",
      "enum": [
        "all",
        "occupied_only"
      ],
      "title": "VacancyInclusion",
      "type": "string"
    },
    "VizType": {
      "description": "Supported chart templates.",
      "enum": [
        "bar",
        "box",
        "histogram"
      ],
      "title": "VizType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Configuration for plot generation",
  "properties": {
    "s3_results_dir": {
      "description": "Path to s3 results directory",
      "title": "S3 Results Dir",
      "type": "string"
    },
    "output_dir": {
      "description": "Path to output directory",
      "title": "Output Dir",
      "type": "string"
    },
    "run_name": {
      "description": "Name of the run to identify it later",
      "title": "Run Name",
      "type": "string"
    },
    "upgrades": {
      "description": "List of upgrade indices to include",
      "items": {
        "type": "integer"
      },
      "title": "Upgrades",
      "type": "array"
    },
    "upgrade_names": {
      "description": "List of upgrade names to include",
      "items": {
        "type": "string"
      },
      "title": "Upgrade Names",
      "type": "array"
    },
    "selection_logic": {
      "anyOf": [
        {
          "$ref": "#/$defs/SelectionLogic"
        },
        {
          "items": {
            "$ref": "#/$defs/SelectionLogic"
          },
          "type": "array"
        },
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Selection logic for",
      "title": "Selection Logic"
    },
    "quantities": {
      "description": "List of quantity groups to generate plots for",
      "items": {
        "$ref": "#/$defs/QuantityGroup"
      },
      "title": "Quantities",
      "type": "array"
    },
    "group_by": {
      "description": "List of grouping columns",
      "items": {
        "type": "string"
      },
      "title": "Group By",
      "type": "array"
    },
    "visualization_types": {
      "description": "List of visualization types to generate",
      "items": {
        "$ref": "#/$defs/VizType"
      },
      "title": "Visualization Types",
      "type": "array"
    },
    "comparison_types": {
      "description": "List of comparison types to generate",
      "items": {
        "$ref": "#/$defs/ComparisonTypes"
      },
      "title": "Comparison Types",
      "type": "array"
    },
    "upgrade_inclusion": {
      "description": "Upgrade inclusion type",
      "items": {
        "$ref": "#/$defs/UpgradeInclusion"
      },
      "title": "Upgrade Inclusion",
      "type": "array"
    },
    "vacancy_inclusion": {
      "description": "Vacancy inclusion type",
      "items": {
        "$ref": "#/$defs/VacancyInclusion"
      },
      "title": "Vacancy Inclusion",
      "type": "array"
    }
  },
  "required": [
    "s3_results_dir",
    "output_dir",
    "run_name",
    "upgrades",
    "upgrade_names",
    "quantities",
    "group_by",
    "visualization_types",
    "comparison_types",
    "upgrade_inclusion",
    "vacancy_inclusion"
  ],
  "title": "WorkflowConfig",
  "type": "object"
}