              <table-calc ordering-type='Columns' type='PctTotal' />
            </column-instance>
            <column-instance column='[Calculation_2192127139618238466]' derivation='User' name='[usr:Calculation_2192127139618238466:qk]' pivot='key' type='quantitative' />
