    <worksheet name='Units by Income, Vintage, and Cooking Fuel'>
      <table>
        <view>
          <datasources>
            <datasource caption='CLEAP_Brainerd_data_with_upgrades' name='federated.0t7txpf1d29a22124p1bx00pz8w3' />
          </datasources>
          <datasource-dependencies datasource='federated.0t7txpf1d29a22124p1bx00pz8w3'>
            <column caption='Income' datatype='string' name='[Area Median Income (copy)_1140255152276176900]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[in.area_median_income]' new-bin='true'>
                <bin default-name='false' value='&quot;High Income&quot;'>
                  <value>&quot;150\%+&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Low and Moderate Income&quot;'>
                  <value>&quot;0-30\%&quot;</value>
                  <value>&quot;30-60\%&quot;</value>
                  <value>&quot;60-80\%&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Medium Income&quot;'>
                  <value>&quot;100-120\%&quot;</value>
                  <value>&quot;120-150\%&quot;</value>
                  <value>&quot;80-100\%&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Unoccupied&quot;'>
                  <value>&quot;Not Available&quot;</value>
                </bin>
              </calculation>
            </column>
            <column caption='Housing Units' datatype='real' name='[Calculation_1140255152274210819]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='round([Calculation_2192127139618238466], -2)' />
            </column>
            <column caption='Cooking Fuel Type' datatype='string' name='[Calculation_1140255152324694025]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [in.cooking_range] = &quot;Gas&quot; THEN &quot;Natural Gas&quot;&#13;&#10;ELSEIF [in.cooking_range] = &quot;Propane&quot; THEN &quot;Propane&quot;&#13;&#10;ELSEIF [in.cooking_range] = &quot;Electric Induction&quot; or [in.cooking_range] = &quot;Electric Resistance&quot; THEN &quot;Electricity&quot;&#13;&#10;ELSE &quot;Other or None&quot;&#13;&#10;END' />
            </column>
            <column caption='Number of Housing Units' datatype='real' name='[Calculation_2192127139618238466]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='countd([bldg_id])&#13;&#10;*&#13;&#10;avg([weight])' />
            </column>
            <column caption='Vintage' datatype='string' name='[In.Vintage (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[in.vintage]' new-bin='true'>
                <bin default-name='false' value='&quot;1940-1979&quot;'>
                  <value>&quot;1940s&quot;</value>
                  <value>&quot;1950s&quot;</value>
                  <value>&quot;1960s&quot;</value>
                  <value>&quot;1970s&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Post-1980&quot;'>
                  <value>&quot;1980s&quot;</value>
                  <value>&quot;1990s&quot;</value>
                  <value>&quot;2000s&quot;</value>
