            <column caption='Water Heater Technology' datatype='string' name='[Calculation_2431380873672228864]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [in.water_heater_efficiency] = &quot;Electric Heat Pump, 50 gal, 3.45 UEF&quot;&#13;&#10;THEN &quot;Electric Heat Pump&quot;&#13;&#10;ELSEIF [in.water_heater_fuel] = &quot;Electricity&quot;&#13;&#10;THEN &quot;Other Electric&quot;&#13;&#10;ELSEIF [in.water_heater_fuel] = &quot;Natural Gas&quot;&#13;&#10;THEN &quot;Natural Gas&quot;&#13;&#10;ELSEIF [in.water_heater_fuel] = &quot;Fuel Oil&quot;&#13;&#10;THEN &quot;Fuel Oil&quot;&#13;&#10;ELSEIF   [in.water_heater_fuel] = &quot;Propane&quot; &#13;&#10;THEN &quot;Propane&quot;&#13;&#10;ELSE &quot;Other Fuel or None&quot;&#13;&#10;END' />
