        <calculation class='tableau' formula='IF [out.2022_inflation_adj_energy_burden_all_fuels] &gt; 0.10 THEN &quot;Severe Burden (&gt;10%)&quot;&#10;ELSEIF [out.2022_inflation_adj_energy_burden_all_fuels] &gt; 0.06 THEN &quot;High Burden (&gt;6%)&quot;&#10;ELSE &quot;Below High Burden Level (&lt;6%)&quot;&#10;END' />
