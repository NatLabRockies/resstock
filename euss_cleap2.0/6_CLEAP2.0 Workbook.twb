    <worksheet name='Buildings by Housing Type and Vintage'>
      <table>
        <view>
          <datasources>
            <datasource caption='CLEAP_Brainerd_data_with_upgrades' name='federated.0t7txpf1d29a22124p1bx00pz8w3' />
          </datasources>
          <datasource-dependencies datasource='federated.0t7txpf1d29a22124p1bx00pz8w3'>
            <column caption='Number of Buildings' datatype='real' name='[Calculation_1749929952234778624]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;IF &#13;&#10;[in.geometry_building_type_recs] = &quot;Single-Family Attached&quot;&#13;&#10;THEN &#13;&#10;[weight]/[in.geometry_building_number_units_sfa]&#13;&#10;ELSEIF ([in.geometry_building_type_recs] = &quot;Single-Family Detached&quot; &#13;&#10;OR [in.geometry_building_type_recs] = &quot;Mobile Home&quot;)&#13;&#10;THEN  [weight]&#13;&#10;ELSE &#13;&#10;[weight] / [in.geometry_building_number_units_mf]&#13;&#10;END&#13;&#10;)' />
            </column>
            <column caption='Vintage' datatype='string' name='[In.Vintage (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[in.vintage]' new-bin='true'>
                <bin default-name='false' value='&quot;1940-1979&quot;'>
                  <value>&quot;1940s&quot;</value>
                  <value>&quot;1950s&quot;</value>
                  <value>&quot;1960s&quot;</value>
                  <value>&quot;1970s&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Post-1980&quot;'>
                  <value>&quot;1980s&quot;</value>
                  <value>&quot;1990s&quot;</value>
                  <value>&quot;2000s&quot;</value>
                  <value>&quot;2010s&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Pre-1940&quot;'>
                  <value>&quot;&lt;1940&quot;</value>
                </bin>
              </calculation>
            </column>
            <column caption='Column' datatype='string' name='[column]' role='dimension' type='nominal' />
            <column caption='County' datatype='string' name='[in.county_name]' role='dimension' semantic-role='[County].[Name]' type='nominal' />
            <column aggregation='Sum' caption='In.Geometry Building Number Units Mf' datatype='real' name='[in.geometry_building_number_units_mf]' role='dimension' type='ordinal' />
            <column aggregation='Sum' caption='In.Geometry Building Number Units Sfa' datatype='real' name='[in.geometry_building_number_units_sfa]' role='dimension' type='ordinal' />
            <column caption='Housing Type (RECS)' datatype='string' name='[in.geometry_building_type_recs]' role='dimension' type='nominal' />
            <column caption='In.Vintage' datatype='string' name='[in.vintage]' role='dimension' type='nominal' />
            <column-instance column='[column]' derivation='None' name='[none:column:nk]' pivot='key' type='nominal' />
            <column-instance column='[in.county_name]' derivation='None' name='[none:in.county_name:nk]' pivot='key' type='nominal' />
            <column-instance column='[in.geometry_building_type_recs]' derivation='None' name='[none:in.geometry_building_type_recs:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1749929952234778624]' derivation='Sum' name='[pcto:sum:Calculation_1749929952234778624:qk:2]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Columns' type='PctTotal' />
