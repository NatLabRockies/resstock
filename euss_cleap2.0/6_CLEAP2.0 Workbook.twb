    <worksheet name='Count of Occupied Houses by Income, Occupancy, and Energy Burden'>
      <table>
        <view>
          <datasources>
            <datasource caption='CLEAP_Brainerd_data_with_upgrades' name='federated.0t7txpf1d29a22124p1bx00pz8w3' />
          </datasources>
          <datasource-dependencies datasource='federated.0t7txpf1d29a22124p1bx00pz8w3'>
            <column caption='Income' datatype='string' name='[Area Median Income (copy)_1140255152276176900]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[in.area_median_income]' new-bin='true'>
                <bin default-name='false' value='&quot;High Income&quot;'>
                  <value>&quot;150\%+&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Low and Moderate Income&quot;'>
                  <value>&quot;0-30\%&quot;</value>
                  <value>&quot;30-60\%&quot;</value>
                  <value>&quot;60-80\%&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Medium Income&quot;'>
                  <value>&quot;100-120\%&quot;</value>
                  <value>&quot;120-150\%&quot;</value>
                  <value>&quot;80-100\%&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Unoccupied&quot;'>
                  <value>&quot;Not Available&quot;</value>
                </bin>
              </calculation>
            </column>
            <column caption='Housing Units' datatype='real' name='[Calculation_1140255152274210819]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='round([Calculation_2192127139618238466], -2)' />
            </column>
            <column caption='Energy Burden' datatype='string' name='[Calculation_1140255152302993415]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [out.energy_burden.percentage] &gt; 10 THEN &quot;Severe Burden (&gt;10%)&quot;&#13;&#10;ELSEIF [out.energy_burden.percentage] &gt; 6 THEN &quot;High Burden (&gt;6%)&quot;&#13;&#10;ELSE &quot;Below High Burden Level (&lt;6%)&quot;&#13;&#10;END' />
              <aliases>
                <alias key='&quot;High Burden (&gt;6\%)&quot;' value='High Burden (6%-10%)' />
              </aliases>
            </column>
            <column caption='Number of Housing Units' datatype='real' name='[Calculation_2192127139618238466]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='countd([bldg_id])&#13;&#10;*&#13;&#10;avg([weight])' />
            </column>
            <column datatype='string' name='[Result Type]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Energy Consumption&quot;' value='End Use Energy' />
                <alias key='&quot;Energy Totals&quot;' value='Site Energy' />
              </aliases>
            </column>
            <column caption='Bldg Id' datatype='integer' name='[bldg_id]' role='dimension' type='ordinal' />
            <column caption='In.Area Median Income' datatype='string' name='[in.area_median_income]' role='dimension' type='nominal' />
            <column caption='Housing Type (RECS)' datatype='string' name='[in.geometry_building_type_recs]' role='dimension' type='nominal' />
            <column caption='Occupancy' datatype='string' name='[in.tenure]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Not Available&quot;' value='Unoccupied' />
              </aliases>
            </column>
            <column caption='In.Vacancy Status' datatype='string' name='[in.vacancy_status]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1140255152302993415]' derivation='None' name='[none:Calculation_1140255152302993415:nk]' pivot='key' type='nominal' />
            <column-instance column='[Result Type]' derivation='None' name='[none:Result Type:nk]' pivot='key' type='nominal' />
            <column-instance column='[in.geometry_building_type_recs]' derivation='None' name='[none:in.geometry_building_type_recs:nk]' pivot='key' type='nominal' />
            <column-instance column='[in.tenure]' derivation='None' name='[none:in.tenure:nk]' pivot='key' type='nominal' />
