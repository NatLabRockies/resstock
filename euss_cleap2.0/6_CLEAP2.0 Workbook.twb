    <worksheet name='HVAC Type Checks'>
      <table>
        <view>
          <datasources>
            <datasource caption='CLEAP_Brainerd_data_with_upgrades' name='federated.0t7txpf1d29a22124p1bx00pz8w3' />
          </datasources>
          <datasource-dependencies datasource='federated.0t7txpf1d29a22124p1bx00pz8w3'>
            <column caption='HVAC Use Type' datatype='string' name='[Calculation_988540144183939072]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF STARTSWITH([column], &quot;out.electricity.cooling&quot;) THEN &quot;Cooling&quot;&#13;&#10;ELSEIF STARTSWITH([column], &quot;out.electricity.mech_vent&quot;) THEN &quot;Mechanical Ventilation&quot;&#13;&#10;ELSEIF [in.hvac_heating_type_and_fuel] = &quot;Electricity ASHP&quot; &#13;&#10;or [in.hvac_heating_type_and_fuel] = &quot;Electricity MSHP&quot;&#13;&#10;THEN &quot;Heat Pump Heating System&quot;&#13;&#10;ELSEIF STARTSWITH([in.hvac_heating_type_and_fuel], &quot;Electricity&quot;) &#13;&#10;THEN &quot;Electric (non HP) Heating System&quot;&#13;&#10;ELSEIF [in.heating_fuel] = &quot;Natural Gas&quot; THEN &quot;Natural Gas Heating System&quot;&#13;&#10;ELSEIF [in.heating_fuel] = &quot;Fuel Oil&quot; THEN &quot;Fuel Oil Heating System&quot;&#13;&#10;ELSEIF [in.heating_fuel] = &quot;Propane&quot; THEN &quot;Propane Heating System&quot;&#13;&#10;ELSE &quot;Other Fuel Heating System&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[End Use Category]' role='dimension' type='nominal' />
            <column datatype='string' name='[Result Type]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Energy Consumption&quot;' value='End Use Energy' />
                <alias key='&quot;Energy Totals&quot;' value='Site Energy' />
              </aliases>
            </column>
            <column caption='Column' datatype='string' name='[column]' role='dimension' type='nominal' />
            <column caption='Heating Fuel' datatype='string' name='[in.heating_fuel]' role='dimension' type='nominal'>
              <aliases>
                <alias key='%null%' value='No Heating' />
              </aliases>
            </column>
            <column caption='In.Hvac Heating Type And Fuel' datatype='string' name='[in.hvac_heating_type_and_fuel]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_988540144183939072]' derivation='None' name='[none:Calculation_988540144183939072:nk]' pivot='key' type='nominal' />
            <column-instance column='[End Use Category]' derivation='None' name='[none:End Use Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Result Type]' derivation='None' name='[none:Result Type:nk]' pivot='key' type='nominal' />
            <column-instance column='[column]' derivation='None' name='[none:column:nk]' pivot='key' type='nominal' />
            <column-instance column='[in.heating_fuel]' derivation='None' name='[none:in.heating_fuel:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <manual-sort column='[federated.0t7txpf1d29a22124p1bx00pz8w3].[none:Calculation_988540144183939072:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Cooling&quot;</bucket>
              <bucket>&quot;Mechanical Ventilation&quot;</bucket>
              <bucket>&quot;Other Fuel Heating&quot;</bucket>
              <bucket>&quot;Propane Heating&quot;</bucket>
              <bucket>&quot;Fuel Oil Heating&quot;</bucket>
              <bucket>&quot;Natural Gas Heating&quot;</bucket>
              <bucket>&quot;Electric (non HP) Heating&quot;</bucket>
              <bucket>&quot;Heat Pump Heating&quot;</bucket>
            </dictionary>
          </manual-sort>
          <filter class='categorical' column='[federated.0t7txpf1d29a22124p1bx00pz8w3].[none:End Use Category:nk]'>
            <groupfilter function='member' level='[none:End Use Category:nk]' member='&quot;HVAC&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
