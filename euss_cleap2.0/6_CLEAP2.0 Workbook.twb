            <column caption='Heating System Type' datatype='string' name='[Calculation_1140255152278642694]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF &#13;&#10;[in.hvac_heating_efficiency] = &quot;ASHP, SEER 10, 6.2 HSPF&quot; &#13;&#10;OR [in.hvac_heating_efficiency] = &quot;ASHP, SEER 13, 7.7 HSPF&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;ASHP, SEER 15, 8.5 HSPF&quot;&#13;&#10;THEN &quot;Ducted Heat Pump&quot;&#13;&#10;ELSEIF &#13;&#10;[in.hvac_heating_efficiency] = &quot;MSHP, SEER 14.5, 8.2 HSPF&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;MSHP, SEER 29.3, 14 HSPF&quot;&#13;&#10;THEN &quot;Ductless Mini-Split Heat Pump&quot;&#13;&#10;ELSEIF [in.heating_fuel] = &quot;Other Fuel&quot;&#13;&#10;THEN &quot;Other Fuel or None&quot;&#13;&#10;ELSEIF&#13;&#10;[in.hvac_heating_efficiency] = &quot;Electric Baseboard, 100% Efficiency&quot; &#13;&#10;THEN &quot;Electric Baseboard&quot;&#13;&#10;ELSEIF &#13;&#10;[in.hvac_heating_efficiency] = &quot;Electric Boiler, 100% AFUE&quot; &#13;&#10;THEN &quot;Electric Boiler&quot;&#13;&#10;ELSEIF &#13;&#10;[in.hvac_heating_efficiency] = &quot;Electric Furnace, 100% AFUE&quot;&#13;&#10;THEN &quot;Electric Furnace&quot;&#13;&#10;ELSEIF &#13;&#10;[in.hvac_heating_efficiency] = &quot;Shared Heating&quot;&#13;&#10;THEN &quot;Shared Heating&quot;&#13;&#10;ELSEIF &#13;&#10;[in.hvac_heating_efficiency] = &quot;Electric Wall Furnace, 100% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Wall/Floor Furnace, 60% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Wall/Floor Furnace, 68% AFUE&quot;&#13;&#10;THEN &quot;Wall/Floor Furnace&quot;&#13;&#10;ELSEIF ([in.hvac_heating_efficiency] = &quot;Fuel Boiler, 76% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Boiler, 80% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Boiler, 90% AFUE&quot;)&#13;&#10;AND [in.heating_fuel] = &quot;Fuel Oil&quot;&#13;&#10;THEN &quot;Fuel Oil Boiler&quot;&#13;&#10;ELSEIF ([in.hvac_heating_efficiency] = &quot;Fuel Boiler, 76% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Boiler, 80% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Boiler, 90% AFUE&quot;)&#13;&#10;AND [in.heating_fuel] = &quot;Natural Gas&quot;&#13;&#10;THEN &quot;Natural Gas Boiler&quot;&#13;&#10;ELSEIF ([in.hvac_heating_efficiency] = &quot;Fuel Boiler, 76% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Boiler, 80% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Boiler, 90% AFUE&quot;)&#13;&#10;AND [in.heating_fuel] = &quot;Propane&quot;&#13;&#10;THEN &quot;Propane Boiler&quot;&#13;&#10;ELSEIF ([in.hvac_heating_efficiency] = &quot;Fuel Furnace, 60% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Furnace, 76% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Furnace, 80% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Furnace, 92.5% AFUE&quot;)&#13;&#10;AND [in.heating_fuel] = &quot;Fuel Oil&quot;&#13;&#10;THEN &quot;Fuel Oil Furnace&quot;&#13;&#10;ELSEIF ([in.hvac_heating_efficiency] = &quot;Fuel Furnace, 60% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Furnace, 76% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Furnace, 80% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Furnace, 92.5% AFUE&quot;)&#13;&#10;AND [in.heating_fuel] = &quot;Natural Gas&quot;&#13;&#10;THEN &quot;Natural Gas Furnace&quot;&#13;&#10;ELSEIF ([in.hvac_heating_efficiency] = &quot;Fuel Furnace, 60% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Furnace, 76% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Furnace, 80% AFUE&quot;&#13;&#10;OR [in.hvac_heating_efficiency] = &quot;Fuel Furnace, 92.5% AFUE&quot;)&#13;&#10;AND [in.heating_fuel] = &quot;Propane&quot;&#13;&#10;THEN &quot;Propane Furnace&quot;&#13;&#10;&#13;&#10;&#13;&#10;ELSE &quot;Other Fuel or None&quot;&#13;&#10;END' />
            </column>
            <column caption='Number of Housing Units' datatype='real' name='[Calculation_2192127139618238466]' role='measure' type='quantitative'>
