      <column caption='Number of Buildings' datatype='real' name='[Calculation_1749929952234778624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;IF &#13;&#10;[in.geometry_building_type_recs] = &quot;Single-Family Attached&quot;&#13;&#10;THEN &#13;&#10;[weight]/[in.geometry_building_number_units_sfa]&#13;&#10;ELSEIF ([in.geometry_building_type_recs] = &quot;Single-Family Detached&quot; &#13;&#10;OR [in.geometry_building_type_recs] = &quot;Mobile Home&quot;)&#13;&#10;THEN  [weight]&#13;&#10;ELSE &#13;&#10;[weight] / [in.geometry_building_number_units_mf]&#13;&#10;END&#13;&#10;)' />
      </column>
