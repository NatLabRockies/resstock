    <worksheet name='Number of Houses by Heating System Type'>
      <table>
        <view>
          <datasources>
            <datasource caption='CLEAP_Brainerd_data_with_upgrades' name='federated.0t7txpf1d29a22124p1bx00pz8w3' />
          </datasources>
          <datasource-dependencies datasource='federated.0t7txpf1d29a22124p1bx00pz8w3'>
            <column caption='Housing Units' datatype='real' name='[Calculation_1140255152274210819]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='round([Calculation_2192127139618238466], -2)' />
            </column>
            <column caption='Number of Housing Units' datatype='real' name='[Calculation_2192127139618238466]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='countd([bldg_id])&#13;&#10;*&#13;&#10;avg([weight])' />
            </column>
            <column caption='HVAC Heating System Type' datatype='string' name='[In.Hvac Heating Efficiency (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[in.hvac_heating_efficiency]' new-bin='true'>
                <bin default-name='false' value='&quot;Boiler&quot;'>
                  <value>&quot;Electric Boiler, 100\% AFUE&quot;</value>
                  <value>&quot;Fuel Boiler, 76\% AFUE&quot;</value>
                  <value>&quot;Fuel Boiler, 80\% AFUE&quot;</value>
                  <value>&quot;Fuel Boiler, 90\% AFUE&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Ducted Furnace&quot;'>
                  <value>&quot;Electric Furnace, 100\% AFUE&quot;</value>
                  <value>&quot;Fuel Furnace, 60\% AFUE&quot;</value>
                  <value>&quot;Fuel Furnace, 76\% AFUE&quot;</value>
                  <value>&quot;Fuel Furnace, 80\% AFUE&quot;</value>
                  <value>&quot;Fuel Furnace, 92.5\% AFUE&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Ducted Heat Pump&quot;'>
                  <value>&quot;ASHP, SEER 10, 6.2 HSPF&quot;</value>
                  <value>&quot;ASHP, SEER 13, 7.7 HSPF&quot;</value>
                  <value>&quot;ASHP, SEER 15, 8.5 HSPF&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;No Heating&quot;'>
                  <value>%null%</value>
                </bin>
                <bin default-name='false' value='&quot;Non-Ducted Heat Pump&quot;'>
                  <value>&quot;MSHP, SEER 14.5, 8.2 HSPF&quot;</value>
                  <value>&quot;MSHP, SEER 29.3, 14 HSPF&quot;</value>
                </bin>
