            <column-instance column='[Calculation_1140255152274210819]' derivation='User' name='[usr:Calculation_1140255152274210819:qk]' pivot='key' type='quantitative' />
            <column caption='Weight' datatype='real' name='[weight]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.0t7txpf1d29a22124p1bx00pz8w3].[In.Vintage (group)]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Post-1980&quot;</bucket>
