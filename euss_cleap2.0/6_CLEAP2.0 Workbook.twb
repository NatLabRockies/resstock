              <calculation class='tableau' formula='countd([bldg_id])&#13;&#10;*&#13;&#10;avg([weight])' />
            </column>
            <column caption='Inflation Adjusted Energy Burden' datatype='string' name='[Calculation_6348245931516686342]' role='dimension' type='nominal'>
