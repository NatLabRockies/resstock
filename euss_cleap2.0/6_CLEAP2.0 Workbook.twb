          <bin default-name='false' value='&quot;Electricity - Propane or Other&quot;'>
            <value>&quot;Electricity - Other Fuel&quot;</value>
            <value>&quot;Electricity - Propane&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;Fuel Oil - Propane or Other&quot;'>
            <value>&quot;Fuel Oil - Other Fuel&quot;</value>
            <value>&quot;Fuel Oil - Propane&quot;</value>
          </bin>
          <bin default-name='false' value='&quot;No Heating or Water Heating&quot;'>
